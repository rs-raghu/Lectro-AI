# .env.example — Copy to .env and fill in your values. Never commit .env.

# Flask <-> ESP32 shared secret
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_AUTH_TOKEN=change_this_to_a_long_random_string

# Gemini API key (free tier at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
